# Copiar a .env y ajustar valores locales. Este archivo SÍ se versiona en git (.env no).

DATABASE_URL="postgresql://infinivirt:infinivirt@localhost:5432/infinivirt?schema=public"

# --- App ---
PORT=3000
NODE_ENV=development

# --- JWT ---
JWT_ACCESS_SECRET="change-me"
