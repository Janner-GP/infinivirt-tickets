# Copia este archivo a `.env` (en la raíz del proyecto) y reemplaza los
# valores antes de correr `docker compose up --build`. `.env` está en
# .gitignore — nunca subas secretos reales al repositorio.
#
#   cp .env.template .env

# --- PostgreSQL ---
POSTGRES_USER=infinivirt
POSTGRES_PASSWORD=change-me
POSTGRES_DB=infinivirt

# --- Backend: JWT ---
# Genera valores aleatorios propios, por ejemplo con:
#   openssl rand -hex 32
JWT_ACCESS_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me
JWT_REFRESH_EXPIRES_IN=7d
